{
	"name": "fairygitmother-patrol",
	"version": "0.1.0",
	"description": "Codebase guardian — idle agents patrol your repos for bugs, drift, and quality issues. MCP server for Claude Code and Antigravity.",
	"type": "module",
	"bin": {
		"fairygitmother-patrol": "./dist/index.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsx watch src/index.ts",
		"start": "tsx src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"inspector": "npx @modelcontextprotocol/inspector dist/index.js"
	},
	"dependencies": {
		"@libsql/client": "^0.14.0",
		"@modelcontextprotocol/sdk": "^0.6.0",
		"drizzle-orm": "^0.38.0",
		"octokit": "^4.1.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.0.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild", "@biomejs/biome"]
	}
}
